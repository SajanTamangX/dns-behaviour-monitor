# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
*.manifest
*.spec

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Test / lint caches ───────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/

# ── IDE / OS ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Streamlit ────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

# ── Pi-hole runtime state (created on container start, never committed) ──────
# Keep docker-compose.yml + a .gitkeep in each bind-mount folder so the host
# directory exists on a fresh clone. Ignore everything else under those dirs.
pihole/etc-pihole/*
pihole/etc-dnsmasq.d/*
pihole/logs/*
!pihole/etc-pihole/.gitkeep
!pihole/etc-dnsmasq.d/.gitkeep
!pihole/logs/.gitkeep

# ── Datasets ─────────────────────────────────────────────────────────────────
# Generated by scripts/generate_traffic.ps1 + export_dataset.ps1.
# Tracked sample logs (baseline/burst/nxdomain/longdomain/sanity-check) stay in
# git via explicit !rules below so a marker can run analysis without Pi-hole.
data/*.log
!data/baseline.log
!data/burst.log
!data/nxdomain.log
!data/longdomain.log
!data/sanity-check.log

# ── Analysis outputs ─────────────────────────────────────────────────────────
# A canonical reference run is committed (summary.json, findings.json,
# parse_stats.json, evaluation_summary.md). Re-runs overwrite these in place,
# which is fine; transient files are ignored below.
outputs/**/*.tmp
outputs/**/*.bak
outputs/evaluation_tables/
